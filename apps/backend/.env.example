# Watcher backend — ortam değişkenleri. Boş bırakılan opsiyoneller fallback'e düşer.
NODE_ENV=production
PORT=3000

# ZORUNLU (üretim): Supabase + Postgres. Boşsa repo in-memory'ye düşer (yalnız geliştirme).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres
# (DATABASE_URL boşsa kuyruk in-memory; üretimde pg-boss için gerekli.)

# Arama + muhakeme. Boşsa StubChecker (gerçek tespit yapmaz).
SERPER_API_KEY=
TAVILY_API_KEY=
# LLM anahtarları (ADR-095): admin konsolundan model seçilir (Groq Llama /
# DeepSeek V4 Flash / V4 Pro / Reasoner). Anahtarı tanımlı olmayan sağlayıcının
# modeli seçilemez. ANAHTARI ASLA repoya yazma — Render env grubuna gir.
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# Gömme / embedding (RAG, ADR-127). Admin → Embeddings'ten sağlayıcı seçilir; anahtarı
# tanımlı OLMAYAN sağlayıcı seçilemez. Gemini ÜCRETSİZ varsayılan; OpenAI alternatif.
# OpenAI'ı admin'de "seçilebilir" yapmak için Render env'e bir OPENAI_API_KEY gir.
# RAG Faz 5'e dek DORMANT (embed() çağrılmaz) → placeholder güvenli; gerçek key gelince değiştir.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Sağlayıcı kullanım panosu (ADR-095, admin → Kaynaklar). Hepsi opsiyonel;
# tanımsız olan kart konsolda dürüstçe "token yok" gösterir.
SUPABASE_ACCESS_TOKEN=
RENDER_API_KEY=
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# Push (FCM v1). Boşsa NoopNotifier (bildirim göndermez).
FCM_PROJECT_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Admin kullanıcı id'leri (virgülle). Opsiyonel.
ADMIN_USER_IDS=

# Hız limitleri (opsiyonel; varsayılan 120 / 30).
RATE_LIMIT_PER_MINUTE=120
WATCH_CREATE_PER_HOUR=30
