# Watcher backend — ortam değişkenleri. Boş bırakılan opsiyoneller fallback'e düşer.
NODE_ENV=production
PORT=3000

# ZORUNLU (üretim): Supabase + Postgres. Boşsa repo in-memory'ye düşer (yalnız geliştirme).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres
# (DATABASE_URL boşsa kuyruk in-memory; üretimde pg-boss için gerekli.)

# Arama + muhakeme. Boşsa StubChecker (gerçek tespit yapmaz).
SERPER_API_KEY=
TAVILY_API_KEY=
DEEPSEEK_API_KEY=

# Push (FCM v1). Boşsa NoopNotifier (bildirim göndermez).
FCM_PROJECT_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Admin kullanıcı id'leri (virgülle). Opsiyonel.
ADMIN_USER_IDS=

# Hız limitleri (opsiyonel; varsayılan 120 / 30).
RATE_LIMIT_PER_MINUTE=120
WATCH_CREATE_PER_HOUR=30
