# ── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
# Optional model overrides (defaults are the June-2026 current ids; re-pin if needed)
GEMINI_TEXT_MODEL=gemini-3.5-flash
GEMINI_REASONING_MODEL=gemini-3.1-pro-preview
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
EMBED_DIM=768                 # MUST equal vector(N) in supabase/schema.sql
TTS_VOICE=Kore                # one of the 30 prebuilt Gemini TTS voices

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=    # server/worker only — never expose to the browser
SUPABASE_ANON_KEY=

# ── YouTube Data API v3 (OAuth) ──────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:5173/oauth2callback
YOUTUBE_REFRESH_TOKEN=        # mint once with the consent helper (see HANDOFF.md §5)

# ── Worker / pipeline ────────────────────────────────────────────────────────
WORK_DIR=/tmp/shorts
TICK_MS=300000                # loop interval (5 min) when running as a worker
ORIGINALITY_THRESHOLD=0.9     # refuse drafts more similar than this to a recent video

# ── AAA layers (added in v0.2) ───────────────────────────────────────────────
APP_PASSWORD=                 # single-user web login (private lock). Use a long random string.
LOG_LEVEL=info                # debug | info | warn | error
DAILY_USD_CAP=5               # auto-pause the pipeline past this daily spend (0 = unlimited)
DAILY_YOUTUBE_UNITS_CAP=8000  # auto-pause past this daily YouTube quota usage
LEASE_SECONDS=900             # job lock TTL (stale locks reclaimed after this)

# ── v0.3 additions ───────────────────────────────────────────────────────────
YOUTUBE_DEFAULT_PRIVACY=private   # private | unlisted | public  (unverified API projects are forced private until Google audit)
SESSION_SECRET=                   # long random string; signs the login cookie (don't reuse APP_PASSWORD)
ALERT_WEBHOOK_URL=                # Slack/Discord/Telegram-style incoming webhook for dead-letter/budget alerts
WORKER_TOKEN=                     # shared secret to trigger the worker's POST /tick (cron/pg_net)
PORT=8080                         # worker http port (serve mode)

# ── v0.4 — editorial agent board + precise rate limits ───────────────────────
REVIEWER_QUORUM=5         # ≥ this many of the 6 auditors must pass to auto-approve
MAX_REVISE_ROUNDS=2       # revise attempts before escalating to a human
REVIEW_MODEL=             # model for the auditors (default: text/flash model)
REVISE_MODEL=             # model for revisions (default: reasoning/pro model)
# Override real rate limits for your tier (defaults are conservative free-tier).
# minIntervalMs = floor(60000/rpm)+1. Example for Tier 1:
# RATE_LIMITS_JSON={"gemini-text":{"rpm":300,"tpm":1000000,"rpd":10000},"gemini-reasoning":{"rpm":150,"tpm":1000000,"rpd":5000},"gemini-image":{"rpm":60,"ipm":60}}
RATE_LIMITS_JSON=

# ── v0.5 — agent swarm orchestration ─────────────────────────────────────────
AGENT_MODE=swarm          # "swarm" (dynamic plan + tool-using sub-agents) | "board" (simpler, cheaper)
SWARM_MAX_PARALLEL=3      # max sub-agents running at once
SWARM_STEP_BUDGET=40      # global cap on coordinated agent steps per video (bounds cost/time)
SWARM_RETRIES=1           # supervisor retries per failed sub-task

# ── v0.6 — research-driven agent upgrades ────────────────────────────────────
SWARM_REPLAN_ROUNDS=1     # replan attempts when sub-tasks fail (0 to disable)
AGENT_GUARDRAILS=on       # input guardrail (topic safety/value pre-check) on|off

# ── v0.7 — autonomy / self-improvement (opt-in, PR-gated) ────────────────────
GITHUB_TOKEN=                 # fine-grained/classic token with `repo` scope (PR + contents + checks)
GITHUB_OWNER=                 # repo owner (user/org)
GITHUB_REPO=                  # repo name
GITHUB_BASE_BRANCH=main
# GITHUB_API_VERSION=2022-11-28
SELF_IMPROVE_ENABLED=off      # open improvement PRs from opportunities (off until you've set GitHub creds)
SELF_IMPROVE_AUTOMERGE=off    # auto-merge ONLY low-risk + green CI (keep off to require human merge)
MONITOR_ENABLED=on            # broad signal monitor + memory self-heal
AUTONOMY_EVERY_TICKS=20       # run the autonomy pass every N ticks
RATELIMIT_RESUME_DELAY_MS=120000  # default wait before resuming the SAME request after a rate-limit

# ── v0.8 — crew / full-auto / competitor analysis ───────────────────────────
AUTONOMY_FULL=off             # full-auto (skips human approval AND publishes). RISK: YouTube terminated
                              #   automated channels Jan 2026 — keep off unless you accept that risk.
COMPETITOR_VIDEO_IDS=         # csv of competitor video IDs for comment+transcript analysis
CORE_SRC_DIR=packages/core/src  # path the AAA module auditor scans (when source is on disk)

# ── v0.9 — surgical self-edit / prompt-lab / anomaly autonomy / OTel ─────────
SELF_IMPROVE_CODE=off         # allow SURGICAL code edits (find/replace PRs) on whitelisted modules
PROMPTLAB_ENABLED=off         # GEPA-style prompt auto-improvement (evaluates + stores better prompts)
ANOMALY_AUTONOMY=on           # anomaly→reason→act within the bounded safe action space (audited)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318   # forward gen_ai.* spans (Langfuse/Jaeger/Tempo/Datadog)

# ── v1.0 — crew production path / prompt-swap / canary ──────────────────────
AGENT_MODE=crew               # crew (manager→specialists, default) | swarm | board  (falls back to board on error)
CANARY_WINDOW_MIN=30          # watch window after an auto-merge before judging regression
CANARY_ERROR_DELTA=0.15       # error-rate increase over baseline that triggers an auto-revert PR

# ── v1.2 — GOAP planner / leader election ───────────────────────────────────
# AGENT_MODE=goap        # GOAP plans the pipeline, crew executes (also: crew | swarm | board)
WORKER_ID=worker-1       # identity for DB-lease leader election (autonomy runs only on the leader)

# ── v1.4 — YouTube'u arayüzden bağlama (tek-tıkla) ──────────────────────────
# Artık /settings sayfasındaki "Connect YouTube" butonuyla bağlanılır; refresh token
# Supabase'deki oauth_tokens tablosuna yazılır (env YOUTUBE_REFRESH_TOKEN opsiyonel fallback).
# Google Cloud Console > OAuth client'ta YETKİLİ YÖNLENDİRME URI'si TAM olarak şu olmalı:
YOUTUBE_REDIRECT_URI=https://<web-domaininiz>/api/youtube/callback
